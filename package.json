{
  "name": "metar-reader",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "server": "node server.js",
    "client": "cd client && npm run dev",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "install:all": "npm install && cd client && npm install",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:all": "npm test && npm --prefix client test"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "supertest": "^7.2.2",
    "vitest": "^4.1.6"
  }
}
